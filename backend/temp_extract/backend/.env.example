# ============================================
# BORSA API - Environment Configuration
# ============================================

# Uygulama
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/borsa_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_CACHE_DB=3

# Logging
LOG_LEVEL=debug

# Yahoo Finance (opsiyonel rate limit ayarları)
YAHOO_RATE_LIMIT_PER_MINUTE=30

# AI/ML
ML_MODEL_PATH=./models
ENABLE_AI_LEARNING=true
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# Admin
ADMIN_API_KEY=your-admin-api-key

# Email (bildirimler için)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# External APIs
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
