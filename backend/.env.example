# ─── Sunucu ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend URL (CORS) ──────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=SUPER_SECRET_JWT_KEY_CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ─── Veritabanı (SQLite - geliştirme) ────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── PostgreSQL (üretim - isteğe bağlı) ──────────────────────────────────────
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/finansradar?schema=public"

# ─── Redis Cache (isteğe bağlı — yoksa in-memory kullanılır) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── Email (bildirimler için isteğe bağlı) ───────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
